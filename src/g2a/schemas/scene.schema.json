{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godot2amiga.org/schemas/g2a/scene.schema.json",
  "title": "Godot2Amiga scene document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source",
    "root"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "source": {
      "type": "string"
    },
    "root": {
      "$ref": "#/$defs/node"
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "type",
        "parent",
        "children"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "properties": {
          "$ref": "#/$defs/nodeProperties",
          "properties": {
            "animation": {
              "type": "string",
              "minLength": 1
            },
            "autoplay": {
              "oneOf": [
                {
                  "type": "null"
                },
                {
                  "type": "string",
                  "minLength": 1
                }
              ]
            },
            "frame": {
              "type": "integer",
              "minimum": 0
            },
            "playing": {
              "type": "boolean"
            },
            "speed_scale": {
              "type": "number"
            },
            "animations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/spriteAnimation"
              }
            }
          }
        }
      }
    },
    "position2d": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        }
      }
    },
    "nodeProperties": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "texture": {
          "type": "string",
          "minLength": 1
        },
        "texture_id": {
          "type": "string",
          "minLength": 1
        },
        "position": {
          "$ref": "#/$defs/position2d"
        },
        "visible": {
          "type": "boolean",
          "default": true
        },
        "z_index": {
          "type": "integer",
          "default": 0
        },
        "animation": {
          "type": "string",
          "minLength": 1
        },
        "autoplay": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "frame": {
          "type": "integer",
          "minimum": 0
        },
        "playing": {
          "type": "boolean"
        },
        "speed_scale": {
          "type": "number"
        },
        "animations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/spriteAnimation"
          }
        }
      }
    },
    "animationFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "texture",
        "duration"
      ],
      "properties": {
        "texture": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "duration": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "animation": {
          "type": "string",
          "minLength": 1
        },
        "autoplay": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "frame": {
          "type": "integer",
          "minimum": 0
        },
        "playing": {
          "type": "boolean"
        },
        "speed_scale": {
          "type": "number"
        },
        "animations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/spriteAnimation"
          }
        }
      }
    },
    "spriteAnimation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "speed_fps",
        "loop",
        "frames"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "speed_fps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "loop": {
          "type": "boolean"
        },
        "frames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/animationFrame"
          }
        }
      }
    }
  }
}
